# ── BASE DE DATOS ──────────────────────────────────────────
DATABASE_URL="postgresql://usuario:contraseña@localhost:5432/futuro_antioquia"

# ── JWT ────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="CAMBIAR_POR_SECRETO_SEGURO_64_BYTES"
JWT_REFRESH_SECRET="CAMBIAR_POR_OTRO_SECRETO_SEGURO_64_BYTES"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ── SERVIDOR ───────────────────────────────────────────────
PORT=4000
NODE_ENV="development"
FRONTEND_URL="http://localhost:3000"

# ── REDIS (Blacklist de tokens + Rate limit) ───────────────
REDIS_URL="redis://localhost:6379"

# ── EMAIL (Resend) ─────────────────────────────────────────
RESEND_API_KEY="re_XXXXXXXXXXXXXXXXXXXXX"
EMAIL_FROM="noreply@futuroantioquia.com"
EMAIL_FROM_NAME="Futuro Antioquia"

# ── SEGURIDAD ──────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30

# ── AWS S3 (Documentos y fotos) ────────────────────────────
AWS_ACCESS_KEY_ID="AKIAXXXXXXXXXXXXXXXX"
AWS_SECRET_ACCESS_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="futuro-antioquia-docs"
