// ============================================================
// FUTURO ANTIOQUIA — Prisma Schema
// PostgreSQL 16 | Generado desde database_schema.sql
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ──────────────────────────────────────────────────

enum RolUsuario {
  administracion
  contable
  profesor
  padre

  @@map("rol_usuario")
}

enum EstadoPago {
  pendiente
  pagado
  vencido
  cancelado
  reembolsado

  @@map("estado_pago")
}

enum TipoMensaje {
  texto
  imagen
  documento
  audio

  @@map("tipo_mensaje")
}

enum TipoConversacion {
  directa
  grupo
  anuncio

  @@map("tipo_conversacion")
}

enum PlanSuscripcion {
  starter
  basico
  pro
  enterprise

  @@map("plan_suscripcion")
}

enum EstadoAlumno {
  activo
  inactivo
  suspendido
  retirado

  @@map("estado_alumno")
}

enum TipoAsistencia {
  presente
  ausente
  tardanza
  excusa_medica
  excusa_familiar

  @@map("tipo_asistencia")
}

enum TipoDocumento {
  consentimiento_informado
  ficha_medica
  poliza_accidentes
  acta_compromiso
  certificado_medico
  foto_perfil
  otro

  @@map("tipo_documento")
}

enum EstadoUniforme {
  asignado
  devuelto
  perdido
  danado

  @@map("estado_uniforme")
}

// ── MODELOS ────────────────────────────────────────────────

model Academia {
  id                    String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  nombre                String          @db.VarChar(200)
  nit                   String?         @unique @db.VarChar(20)
  ciudad                String          @default("Medellín") @db.VarChar(100)
  departamento          String          @default("Antioquia") @db.VarChar(100)
  direccion             String?
  telefono              String?         @db.VarChar(20)
  emailContacto         String?         @db.VarChar(200) @map("email_contacto")
  logoUrl               String?         @map("logo_url")
  planSuscripcion       PlanSuscripcion @default(starter) @map("plan_suscripcion")
  suscripcionActiva     Boolean         @default(true) @map("suscripcion_activa")
  fechaVencimientoPlan  DateTime?       @map("fecha_vencimiento_plan")
  maxAlumnos            Int             @default(30) @map("max_alumnos")
  config                Json            @default("{}")
  activa                Boolean         @default(true)
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  // Relations
  usuarios              Usuario[]
  categorias            Categoria[]
  entrenadores          Entrenador[]
  alumnos               Alumno[]
  entrenamientos        Entrenamiento[]
  torneos               Torneo[]
  partidos              Partido[]
  pagos                 Pago[]
  conversaciones        Conversacion[]
  documentos            Documento[]
  uniformes             Uniforme[]
  logsAuditoria         LogAuditoria[]

  @@map("academias")
}

model Usuario {
  id                String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId        String?     @db.Uuid @map("academia_id")
  email             String      @unique @db.VarChar(200)
  passwordHash      String      @map("password_hash")
  nombre            String      @db.VarChar(100)
  apellido          String      @db.VarChar(100)
  telefono          String?     @db.VarChar(20)
  fotoUrl           String?     @map("foto_url")
  rol               RolUsuario
  activo            Boolean     @default(true)
  emailVerificado   Boolean     @default(false) @map("email_verificado")
  dosFactores       Boolean     @default(false) @map("dos_factores")
  dosFactoresSecret String?     @map("dos_factores_secret")
  ultimoLogin       DateTime?   @map("ultimo_login")
  intentosLogin     Int         @default(0) @map("intentos_login")
  bloqueadoHasta    DateTime?   @map("bloqueado_hasta")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relations
  academia              Academia?              @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  refreshTokens         RefreshToken[]
  entrenador            Entrenador?
  padresAlumnos         PadreAlumno[]
  seguimientoFisico     SeguimientoFisico[]
  planesNutricionales   PlanNutricional[]
  habitos               HabitoNutricional[]
  asistenciasRegistradas Asistencia[]
  historialCreado       HistorialDeportivo[]
  mensajes              Mensaje[]
  convParticipaciones   ConversacionParticipante[]
  notificaciones        Notificacion[]
  pushTokens            PushToken[]
  documentosSubidos     Documento[]
  pagosGenerados        Pago[]
  logsAuditoria         LogAuditoria[]

  @@map("usuarios")
}

model RefreshToken {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId   String    @db.Uuid @map("usuario_id")
  tokenHash   String    @unique @map("token_hash")
  expiresAt   DateTime  @map("expires_at")
  revocado    Boolean   @default(false)
  dispositivo String?
  ipAddress   String?   @map("ip_address") @db.Inet
  createdAt   DateTime  @default(now()) @map("created_at")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Categoria {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId          String    @db.Uuid @map("academia_id")
  nombre              String    @db.VarChar(100)
  añoNacimientoMin    Int?      @map("año_nacimiento_min") @db.SmallInt
  añoNacimientoMax    Int?      @map("año_nacimiento_max") @db.SmallInt
  descripcion         String?
  colorCategoria      String?   @default("#006633") @map("color_categoria") @db.VarChar(7)
  activa              Boolean   @default(true)
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  academia            Academia  @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  entrenadorCategorias EntrenadorCategoria[]
  alumnos             Alumno[]
  entrenamientos      Entrenamiento[]
  torneoCategorias    TorneoCategoria[]
  partidos            Partido[]
  conversaciones      Conversacion[]

  @@unique([academiaId, nombre])
  @@map("categorias")
}

model Entrenador {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId        String    @unique @db.Uuid @map("usuario_id")
  academiaId       String    @db.Uuid @map("academia_id")
  especialidad     String?   @db.VarChar(200)
  certificaciones  String[]
  añosExperiencia  Int?      @map("años_experiencia") @db.SmallInt
  biografia        String?
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  usuario          Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  academia         Academia  @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  categorias       EntrenadorCategoria[]
  evaluacionesTecnicas EvaluacionTecnica[]
  evaluacionesFormativas EvaluacionFormativa[]
  metas            MetaIndividual[]
  entrenamientos   Entrenamiento[]

  @@map("entrenadores")
}

model EntrenadorCategoria {
  entrenadorId  String      @db.Uuid @map("entrenador_id")
  categoriaId   String      @db.Uuid @map("categoria_id")
  esPrincipal   Boolean     @default(false) @map("es_principal")
  assignedAt    DateTime    @default(now()) @map("assigned_at")

  entrenador    Entrenador  @relation(fields: [entrenadorId], references: [id], onDelete: Cascade)
  categoria     Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([entrenadorId, categoriaId])
  @@map("entrenador_categorias")
}

model Alumno {
  id                        String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId                String        @db.Uuid @map("academia_id")
  categoriaId               String?       @db.Uuid @map("categoria_id")
  nombre                    String        @db.VarChar(100)
  apellido                  String        @db.VarChar(100)
  fechaNacimiento           DateTime      @map("fecha_nacimiento") @db.Date
  genero                    String?       @db.Char(1)
  numeroDocumento           String?       @db.VarChar(30) @map("numero_documento")
  fotoUrl                   String?       @map("foto_url")
  posicionPreferida         String?       @db.VarChar(50) @map("posicion_preferida")
  numeroCamiseta            Int?          @db.SmallInt @map("numero_camiseta")
  estado                    EstadoAlumno  @default(activo)
  fechaIngreso              DateTime      @default(now()) @map("fecha_ingreso") @db.Date
  fechaRetiro               DateTime?     @map("fecha_retiro") @db.Date
  observacionesMedicas      String?       @map("observaciones_medicas")
  grupoSanguineo            String?       @db.VarChar(5) @map("grupo_sanguineo")
  alergias                  String[]
  contactoEmergenciaNombre  String?       @db.VarChar(200) @map("contacto_emergencia_nombre")
  contactoEmergenciaTelefono String?      @db.VarChar(20) @map("contacto_emergencia_telefono")
  createdAt                 DateTime      @default(now()) @map("created_at")
  updatedAt                 DateTime      @updatedAt @map("updated_at")

  academia              Academia          @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  categoria             Categoria?        @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  padresAlumnos         PadreAlumno[]
  asistencias           Asistencia[]
  evaluacionesTecnicas  EvaluacionTecnica[]
  evaluacionesFormativas EvaluacionFormativa[]
  seguimientoFisico     SeguimientoFisico[]
  planesNutricionales   PlanNutricional[]
  habitos               HabitoNutricional[]
  historialDeportivo    HistorialDeportivo[]
  pagos                 Pago[]
  documentos            Documento[]
  uniformes             Uniforme[]
  metas                 MetaIndividual[]

  @@map("alumnos")
}

model PadreAlumno {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  padreId     String    @db.Uuid @map("padre_id")
  alumnoId    String    @db.Uuid @map("alumno_id")
  parentesco  String    @default("padre") @db.VarChar(50)
  esAcudiente Boolean   @default(false) @map("es_acudiente")
  puedeRecoger Boolean  @default(true) @map("puede_recoger")
  createdAt   DateTime  @default(now()) @map("created_at")

  padre       Usuario   @relation(fields: [padreId], references: [id], onDelete: Cascade)
  alumno      Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  @@unique([padreId, alumnoId])
  @@map("padres_alumnos")
}

model Entrenamiento {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId      String      @db.Uuid @map("academia_id")
  categoriaId     String      @db.Uuid @map("categoria_id")
  entrenadorId    String?     @db.Uuid @map("entrenador_id")
  titulo          String      @default("Entrenamiento") @db.VarChar(200)
  descripcion     String?
  fecha           DateTime    @db.Date
  horaInicio      DateTime    @map("hora_inicio") @db.Time
  horaFin         DateTime    @map("hora_fin") @db.Time
  lugar           String      @default("Cancha Principal") @db.VarChar(200)
  cancelado       Boolean     @default(false)
  motivoCancelacion String?   @map("motivo_cancelacion")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  academia        Academia    @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  categoria       Categoria   @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  entrenador      Entrenador? @relation(fields: [entrenadorId], references: [id], onDelete: SetNull)
  asistencias     Asistencia[]

  @@map("entrenamientos")
}

model Asistencia {
  id                String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  entrenamientoId   String          @db.Uuid @map("entrenamiento_id")
  alumnoId          String          @db.Uuid @map("alumno_id")
  estado            TipoAsistencia  @default(presente)
  observacion       String?
  registradoPor     String?         @db.Uuid @map("registrado_por")
  registeredAt      DateTime        @default(now()) @map("registered_at")

  entrenamiento     Entrenamiento   @relation(fields: [entrenamientoId], references: [id], onDelete: Cascade)
  alumno            Alumno          @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  usuario           Usuario?        @relation(fields: [registradoPor], references: [id], onDelete: SetNull)

  @@unique([entrenamientoId, alumnoId])
  @@map("asistencias")
}

model EvaluacionTecnica {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId        String      @db.Uuid @map("alumno_id")
  entrenadorId    String?     @db.Uuid @map("entrenador_id")
  fecha           DateTime    @db.Date
  velocidad       Decimal?    @db.Decimal(3,1)
  resistencia     Decimal?    @db.Decimal(3,1)
  coordinacion    Decimal?    @db.Decimal(3,1)
  controlBalon    Decimal?    @db.Decimal(3,1) @map("control_balon")
  tomaDecisiones  Decimal?    @db.Decimal(3,1) @map("toma_decisiones")
  pasePrecision   Decimal?    @db.Decimal(3,1) @map("pase_precision")
  remate          Decimal?    @db.Decimal(3,1)
  posicionamiento Decimal?    @db.Decimal(3,1)
  // nota_global es columna GENERATED en PostgreSQL — no se mapea en Prisma
  observaciones   String?
  metasProximas   String?     @map("metas_proximas")
  createdAt       DateTime    @default(now()) @map("created_at")

  alumno          Alumno      @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  entrenador      Entrenador? @relation(fields: [entrenadorId], references: [id], onDelete: SetNull)

  @@map("evaluaciones_tecnicas")
}

model EvaluacionFormativa {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId        String    @db.Uuid @map("alumno_id")
  entrenadorId    String?   @db.Uuid @map("entrenador_id")
  mes             Int       @db.SmallInt
  año             Int       @db.SmallInt
  comportamiento  Int?      @db.SmallInt
  disciplina      Int?      @db.SmallInt
  liderazgo       Int?      @db.SmallInt
  trabajoEquipo   Int?      @db.SmallInt @map("trabajo_equipo")
  valores         Int?      @db.SmallInt
  puntualidad     Int?      @db.SmallInt
  observaciones   String?
  recomendaciones String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  alumno          Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  entrenador      Entrenador? @relation(fields: [entrenadorId], references: [id], onDelete: SetNull)

  @@unique([alumnoId, mes, año])
  @@map("evaluaciones_formativas")
}

model SeguimientoFisico {
  id                    String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId              String    @db.Uuid @map("alumno_id")
  registradoPor         String?   @db.Uuid @map("registrado_por")
  fecha                 DateTime  @db.Date
  pesoKg                Decimal?  @db.Decimal(5,2) @map("peso_kg")
  tallaCm               Decimal?  @db.Decimal(5,2) @map("talla_cm")
  // imc es GENERATED en PostgreSQL
  perimetroCinturaCm    Decimal?  @db.Decimal(5,2) @map("perimetro_cintura_cm")
  porcentajeGrasa       Decimal?  @db.Decimal(4,2) @map("porcentaje_grasa")
  observaciones         String?
  createdAt             DateTime  @default(now()) @map("created_at")

  alumno                Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  registrador           Usuario?  @relation(fields: [registradoPor], references: [id], onDelete: SetNull)

  @@map("seguimiento_fisico")
}

model PlanNutricional {
  id                String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId          String    @db.Uuid @map("alumno_id")
  nutricionistaId   String?   @db.Uuid @map("nutricionista_id")
  fechaInicio       DateTime  @map("fecha_inicio") @db.Date
  fechaFin          DateTime? @map("fecha_fin") @db.Date
  caloriasDia       Int?      @db.SmallInt @map("calorias_dia")
  proteinasG        Int?      @db.SmallInt @map("proteinas_g")
  carbohidratosG    Int?      @db.SmallInt @map("carbohidratos_g")
  grasasG           Int?      @db.SmallInt @map("grasas_g")
  menuSemanal       Json?     @map("menu_semanal")
  recomendaciones   String?
  restricciones     String[]
  activo            Boolean   @default(true)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  alumno            Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  nutricionista     Usuario?  @relation(fields: [nutricionistaId], references: [id], onDelete: SetNull)

  @@map("planes_nutricionales")
}

model HabitoNutricional {
  id                  String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId            String    @db.Uuid @map("alumno_id")
  semanaInicio        DateTime  @map("semana_inicio") @db.Date
  hidratacionLitros   Decimal?  @db.Decimal(3,1) @map("hidratacion_litros")
  haceDesayuno        Boolean?  @map("hace_desayuno")
  almuerzoCompleto    Boolean?  @map("almuerzo_completo")
  cenaBalanceada      Boolean?  @map("cena_balanceada")
  snacksSaludables    Boolean?  @map("snacks_saludables")
  consumeFrutas       Boolean?  @map("consume_frutas")
  consumeVerduras     Boolean?  @map("consume_verduras")
  horasSueno          Decimal?  @db.Decimal(3,1) @map("horas_sueño")
  observaciones       String?
  registradoPor       String?   @db.Uuid @map("registrado_por")
  createdAt           DateTime  @default(now()) @map("created_at")

  alumno              Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  registrador         Usuario?  @relation(fields: [registradoPor], references: [id])

  @@unique([alumnoId, semanaInicio])
  @@map("habitos_nutricionales")
}

model Torneo {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId    String    @db.Uuid @map("academia_id")
  nombre        String    @db.VarChar(200)
  descripcion   String?
  fechaInicio   DateTime  @map("fecha_inicio") @db.Date
  fechaFin      DateTime? @map("fecha_fin") @db.Date
  lugar         String?   @db.VarChar(200)
  organizador   String?   @db.VarChar(200)
  logoUrl       String?   @map("logo_url")
  activo        Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  academia      Academia          @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  categorias    TorneoCategoria[]
  partidos      Partido[]

  @@map("torneos")
}

model TorneoCategoria {
  torneoId    String    @db.Uuid @map("torneo_id")
  categoriaId String    @db.Uuid @map("categoria_id")

  torneo      Torneo    @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([torneoId, categoriaId])
  @@map("torneo_categorias")
}

model Partido {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  torneoId        String?   @db.Uuid @map("torneo_id")
  academiaId      String    @db.Uuid @map("academia_id")
  categoriaId     String?   @db.Uuid @map("categoria_id")
  equipoLocal     String    @db.VarChar(200) @map("equipo_local")
  equipoVisitante String    @db.VarChar(200) @map("equipo_visitante")
  esLocal         Boolean   @default(true) @map("es_local")
  fecha           DateTime
  lugar           String?   @db.VarChar(200)
  golesAFavor     Int?      @db.SmallInt @map("goles_favor")
  golesEnContra   Int?      @db.SmallInt @map("goles_contra")
  resultadoFinal  String?   @db.VarChar(20) @map("resultado_final")
  observaciones   String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  torneo          Torneo?   @relation(fields: [torneoId], references: [id], onDelete: SetNull)
  academia        Academia  @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  categoria       Categoria? @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  historial       HistorialDeportivo[]

  @@map("partidos")
}

model HistorialDeportivo {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId    String    @db.Uuid @map("alumno_id")
  partidoId   String?   @db.Uuid @map("partido_id")
  fecha       DateTime  @db.Date
  tipo        String    @db.VarChar(50)
  descripcion String
  createdBy   String?   @db.Uuid @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")

  alumno      Alumno    @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  partido     Partido?  @relation(fields: [partidoId], references: [id], onDelete: SetNull)
  creador     Usuario?  @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@map("historial_deportivo")
}

model Pago {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId          String      @db.Uuid @map("academia_id")
  alumnoId            String      @db.Uuid @map("alumno_id")
  generadoPor         String?     @db.Uuid @map("generado_por")
  concepto            String      @default("Mensualidad") @db.VarChar(200)
  descripcion         String?
  monto               Decimal     @db.Decimal(12,2)
  moneda              String      @default("COP") @db.Char(3)
  fechaVencimiento    DateTime    @map("fecha_vencimiento") @db.Date
  fechaPago           DateTime?   @map("fecha_pago")
  estado              EstadoPago  @default(pendiente)
  metodoPago          String?     @db.VarChar(50) @map("metodo_pago")
  referenciaPago      String?     @db.VarChar(200) @map("referencia_pago")
  referenciaInterna   String?     @unique @map("referencia_interna")
  reciboUrl           String?     @map("recibo_url")
  metadata            Json        @default("{}")
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  academia            Academia    @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  alumno              Alumno      @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  generador           Usuario?    @relation(fields: [generadoPor], references: [id], onDelete: SetNull)

  @@map("pagos")
}

model Conversacion {
  id            String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId    String              @db.Uuid @map("academia_id")
  tipo          TipoConversacion    @default(directa)
  titulo        String?             @db.VarChar(200)
  categoriaId   String?             @db.Uuid @map("categoria_id")
  archivada     Boolean             @default(false)
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")

  academia      Academia            @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  categoria     Categoria?          @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  participantes ConversacionParticipante[]
  mensajes      Mensaje[]

  @@map("conversaciones")
}

model ConversacionParticipante {
  conversacionId  String        @db.Uuid @map("conversacion_id")
  usuarioId       String        @db.Uuid @map("usuario_id")
  esAdmin         Boolean       @default(false) @map("es_admin")
  silenciada      Boolean       @default(false)
  unidoAt         DateTime      @default(now()) @map("unido_at")
  ultimoLeidoAt   DateTime?     @map("ultimo_leido_at")

  conversacion    Conversacion  @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  usuario         Usuario       @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@id([conversacionId, usuarioId])
  @@map("conversacion_participantes")
}

model Mensaje {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  conversacionId  String          @db.Uuid @map("conversacion_id")
  senderId        String          @db.Uuid @map("sender_id")
  contenido       String
  tipo            TipoMensaje     @default(texto)
  mediaUrl        String?         @map("media_url")
  editado         Boolean         @default(false)
  eliminado       Boolean         @default(false)
  respuestaA      String?         @db.Uuid @map("respuesta_a")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  conversacion    Conversacion    @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  sender          Usuario         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  respuesta       Mensaje?        @relation("RespuestaMensaje", fields: [respuestaA], references: [id], onDelete: SetNull)
  respuestas      Mensaje[]       @relation("RespuestaMensaje")

  @@map("mensajes")
}

model Notificacion {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId       String    @db.Uuid @map("usuario_id")
  tipo            String    @db.VarChar(100)
  titulo          String    @db.VarChar(200)
  cuerpo          String
  leida           Boolean   @default(false)
  link            String?
  metadata        Json      @default("{}")
  enviadaPush     Boolean   @default(false) @map("enviada_push")
  enviadaEmail    Boolean   @default(false) @map("enviada_email")
  createdAt       DateTime  @default(now()) @map("created_at")

  usuario         Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

model PushToken {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  usuarioId   String    @db.Uuid @map("usuario_id")
  token       String    @unique
  plataforma  String    @db.VarChar(10)
  activo      Boolean   @default(true)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model Documento {
  id            String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId    String          @db.Uuid @map("academia_id")
  alumnoId      String?         @db.Uuid @map("alumno_id")
  tipo          TipoDocumento
  nombre        String          @db.VarChar(200)
  urlS3         String          @map("url_s3")
  mimeType      String?         @db.VarChar(100) @map("mime_type")
  tamanoBytes   Int?            @map("tamano_bytes")
  subidoPor     String?         @db.Uuid @map("subido_por")
  firmado       Boolean         @default(false)
  fechaFirma    DateTime?       @map("fecha_firma")
  venceEn       DateTime?       @map("vence_en") @db.Date
  createdAt     DateTime        @default(now()) @map("created_at")

  academia      Academia        @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  alumno        Alumno?         @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  subidor       Usuario?        @relation(fields: [subidoPor], references: [id], onDelete: SetNull)

  @@map("documentos")
}

model Uniforme {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId      String          @db.Uuid @map("academia_id")
  alumnoId        String?         @db.Uuid @map("alumno_id")
  codigo          String?         @db.VarChar(50)
  tipo            String          @default("camiseta") @db.VarChar(50)
  talla           String          @db.VarChar(10)
  color           String?         @db.VarChar(50)
  numero          Int?            @db.SmallInt
  estado          EstadoUniforme  @default(asignado)
  fechaEntrega    DateTime?       @map("fecha_entrega") @db.Date
  fechaDevolucion DateTime?       @map("fecha_devolucion") @db.Date
  observaciones   String?
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  academia        Academia        @relation(fields: [academiaId], references: [id], onDelete: Cascade)
  alumno          Alumno?         @relation(fields: [alumnoId], references: [id], onDelete: SetNull)

  @@map("uniformes")
}

model MetaIndividual {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  alumnoId        String      @db.Uuid @map("alumno_id")
  entrenadorId    String?     @db.Uuid @map("entrenador_id")
  titulo          String      @db.VarChar(200)
  descripcion     String?
  categoriaMeta   String?     @db.VarChar(50) @map("categoria_meta")
  fechaObjetivo   DateTime?   @map("fecha_objetivo") @db.Date
  completada      Boolean     @default(false)
  fechaCompletada DateTime?   @map("fecha_completada") @db.Date
  progreso        Int         @default(0) @db.SmallInt
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  alumno          Alumno      @relation(fields: [alumnoId], references: [id], onDelete: Cascade)
  entrenador      Entrenador? @relation(fields: [entrenadorId], references: [id], onDelete: SetNull)

  @@map("metas_individuales")
}

model LogAuditoria {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  academiaId  String?   @db.Uuid @map("academia_id")
  usuarioId   String?   @db.Uuid @map("usuario_id")
  accion      String    @db.VarChar(100)
  recurso     String    @db.VarChar(100)
  recursoId   String?   @db.Uuid @map("recurso_id")
  detalles    Json      @default("{}")
  ipAddress   String?   @map("ip_address") @db.Inet
  userAgent   String?   @map("user_agent")
  createdAt   DateTime  @default(now()) @map("created_at")

  academia    Academia? @relation(fields: [academiaId], references: [id], onDelete: SetNull)
  usuario     Usuario?  @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  // Nota: en producción esta tabla usa PARTITION BY RANGE (created_at) en PostgreSQL
  @@map("logs_auditoria")
}
